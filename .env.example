# ── OAuth (Google Cloud → APIs et services → Identifiants) ───────────────────
#
# Type « Application Web » : ajoute les URI de redirection autorisées, ex. :
#   http://localhost:5173/
# Google exige le client_secret à l’échange du code → en dev local, renseigne-le ci-dessous.
# En production, ne mets pas le secret dans le front : passe par un backend qui échange le code.
#
VITE_GSC_CLIENT_ID=
VITE_GSC_CLIENT_SECRET=

# Propriété GSC à pré-sélectionner si elle est dans la liste des sites.
VITE_GSC_SITE_URL=https://www.jplouton-avocat.fr/

# Optionnel : redirection OAuth (par défaut : ${origin}/).
# VITE_GSC_REDIRECT_URI=http://localhost:5173/

# Dev : le proxy Vite évite le blocage CORS sur l’API Search Console (aucune variable requise).
# Prod : prévoir un relais vers https://www.googleapis.com/webmasters/v3 (API officielle sites + analytics).

# ── DataForSEO API (volumes Google Ads · France / FR) ─────────────────────────
# Identifiants : https://app.dataforseo.com/api-access — lus uniquement par le proxy Vite (pas de préfixe VITE_).
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

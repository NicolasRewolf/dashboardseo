{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreDependencies": [
    "@nivo/bar",
    "@nivo/core",
    "@nivo/line",
    "@nivo/network",
    "@nivo/pie",
    "@nivo/scatterplot",
    "@nivo/treemap",
    "@radix-ui/react-dialog",
    "@radix-ui/react-dropdown-menu",
    "@radix-ui/react-tabs",
    "@react-spring/web",
    "@tanstack/react-table",
    "@visx/visx",
    "cmdk",
    "plotly.js",
    "react-hook-form",
    "react-plotly.js",
    "shadcn",
    "tailwindcss-animate",
    "zod",
    "@types/plotly.js",
    "@types/react-plotly.js"

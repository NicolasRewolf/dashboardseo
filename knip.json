    "src/lib/dashboard-date-presets.ts": ["exports"],
    "src/lib/gsc/api.ts": ["types"],
    "src/lib/gsc/oauth-client.ts": ["exports"],
    "src/lib/gsc/token-storage.ts": ["exports", "types"],
    "src/contexts/dashboard-filters.ts": ["types"],
    "src/contexts/gsc-auth-context.ts": ["types"],
    "src/hooks/use-gsc-dashboard-data.ts": ["types"],
    "src/types/bi.ts": ["types"],
    "src/types/gsc.ts": ["types"],
    "src/lib/dataforseo/volume-cache.ts": ["exports"]
